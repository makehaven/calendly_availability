<?php

/**
 * @file
 * Contains calendly_availability.module.
 */

use Drupal\calendly_availability\Form\CalendlySettingsForm;
use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Url;
use GuzzleHttp\Exception\RequestException;

/**
 * Implements hook_requirements().
 */
function calendly_availability_requirements($phase) {
  $requirements = [];

  if ($phase !== 'runtime') {
    return $requirements;
  }

  $state = \Drupal::state();
  $token = $state->get('calendly_availability.personal_access_token');
  $expires_at = $state->get('calendly_availability.token_expires_at');
  $last_refresh_error = $state->get('calendly_availability.last_refresh_error_time');
  $last_refresh_message = $state->get('calendly_availability.last_refresh_error_message');
  $last_api_error = $state->get('calendly_availability.last_api_error_time');
  $settings_url = Url::fromRoute('calendly_availability.settings')->toString();

  if (empty($token)) {
    $requirements['calendly_availability_token'] = [
      'title' => t('Calendly Integration'),
      'value' => t('Not authorized'),
      'description' => t('The Calendly integration is not authorized. New members cannot book tours or orientations. <a href=":url">Re-authorize now</a>.', [':url' => $settings_url]),
      'severity' => REQUIREMENT_ERROR,
    ];
  }
  elseif ($expires_at && time() > $expires_at) {
    $requirements['calendly_availability_token'] = [
      'title' => t('Calendly Integration'),
      'value' => t('Token expired'),
      'description' => t('The Calendly OAuth token has expired and could not be automatically refreshed. New members cannot book tours or orientations. <a href=":url">Re-authorize now</a>.', [':url' => $settings_url]),
      'severity' => REQUIREMENT_ERROR,
    ];
  }
  elseif ($expires_at && time() > ($expires_at - 86400)) {
    // Warn within 24 hours of expiry.
    $requirements['calendly_availability_token'] = [
      'title' => t('Calendly Integration'),
      'value' => t('Token expiring soon'),
      'description' => t('The Calendly OAuth token expires within 24 hours. <a href=":url">Re-authorize now</a> to avoid disruption.', [':url' => $settings_url]),
      'severity' => REQUIREMENT_WARNING,
    ];
  }
  else {
    $requirements['calendly_availability_token'] = [
      'title' => t('Calendly Integration'),
      'value' => t('Authorized'),
      'severity' => REQUIREMENT_OK,
    ];
  }

  // Surface recent refresh failures even if a token is still nominally valid.
  if ($last_refresh_error && (time() - $last_refresh_error) < 86400) {
    $requirements['calendly_availability_recent_refresh_error'] = [
      'title' => t('Calendly Token Refresh'),
      'value' => t('Recent refresh failure'),
      'description' => t('Calendly token refresh failed within the last 24 hours. Last error: @msg. Check logs and re-authorize if needed.', [
        '@msg' => $last_refresh_message ?? 'unknown',
      ]),
      'severity' => REQUIREMENT_WARNING,
    ];
  }

  if ($last_api_error && (time() - $last_api_error) < 86400) {
    $requirements['calendly_availability_recent_api_error'] = [
      'title' => t('Calendly API'),
      'value' => t('Recent API failure'),
      'description' => t('A Calendly API call failed within the last 24 hours. Users are seeing the fallback link. Review the <a href=":logs">recent log messages</a>.', [
        ':logs' => Url::fromRoute('dblog.overview', [], ['query' => ['type[]' => 'calendly_availability']])->toString(),
      ]),
      'severity' => REQUIREMENT_WARNING,
    ];
  }

  return $requirements;
}

/**
 * Implements hook_cron().
 *
 * Proactively refreshes the Calendly OAuth token when it is within 24 hours
 * of expiry, so we don't rely on a page visit to trigger refresh. Rate-limited
 * to once per hour to avoid thrashing on every cron run.
 */
function calendly_availability_cron() {
  $state = \Drupal::state();
  $last_attempt = $state->get('calendly_availability.cron_last_attempt', 0);
  if ($last_attempt && (time() - $last_attempt) < 3600) {
    return;
  }

  $refresh_token = $state->get('calendly_availability.refresh_token');
  $expires_at = $state->get('calendly_availability.token_expires_at');
  if (empty($refresh_token) || empty($expires_at)) {
    return;
  }

  if (time() < ($expires_at - 86400)) {
    return;
  }

  $state->set('calendly_availability.cron_last_attempt', time());

  $config = \Drupal::config('calendly_availability.settings');
  $credentials = CalendlySettingsForm::getCredentialsForCurrentHost($config);
  $client_id = $credentials['client_id'] ?? '';
  $client_secret = $credentials['client_secret'] ?? '';
  $logger = \Drupal::logger('calendly_availability');

  if (empty($client_id) || empty($client_secret)) {
    $logger->warning('Cron refresh skipped: no OAuth client credentials for current host.');
    return;
  }

  try {
    $response = \Drupal::httpClient()->post('https://auth.calendly.com/oauth/token', [
      'form_params' => [
        'grant_type' => 'refresh_token',
        'refresh_token' => $refresh_token,
        'client_id' => $client_id,
        'client_secret' => $client_secret,
      ],
    ]);
    $data = json_decode($response->getBody()->getContents(), TRUE);
    if (!empty($data['access_token'])) {
      $state->set('calendly_availability.personal_access_token', $data['access_token']);
      $state->set('calendly_availability.refresh_token', $data['refresh_token'] ?? $refresh_token);
      $state->set('calendly_availability.token_expires_at', time() + ($data['expires_in'] ?? 3600));
      $state->delete('calendly_availability.last_refresh_error_time');
      $state->delete('calendly_availability.last_refresh_error_message');
      $logger->info('Cron proactively refreshed Calendly access token.');
    }
    else {
      _calendly_availability_record_cron_failure('empty_response', 'Refresh response lacked access_token.');
    }
  }
  catch (RequestException $e) {
    $status = $e->hasResponse() ? $e->getResponse()->getStatusCode() : 0;
    $body = $e->hasResponse() ? (string) $e->getResponse()->getBody() : '';
    $logger->error('Cron Calendly refresh failed (HTTP @code): @msg', ['@code' => $status, '@msg' => $e->getMessage()]);
    if (in_array($status, [400, 401], TRUE)) {
      $state->delete('calendly_availability.personal_access_token');
      $state->delete('calendly_availability.refresh_token');
      $state->delete('calendly_availability.token_expires_at');
      _calendly_availability_record_cron_failure('auth_revoked', sprintf('HTTP %d; tokens cleared. Body: %s', $status, $body));
    }
    else {
      _calendly_availability_record_cron_failure('http_error', sprintf('HTTP %d: %s', $status, $e->getMessage()));
    }
  }
}

/**
 * Helper: records a cron refresh failure and fires an alert.
 */
function _calendly_availability_record_cron_failure(string $reason, string $message): void {
  $state = \Drupal::state();
  $state->set('calendly_availability.last_refresh_error_time', time());
  $state->set('calendly_availability.last_refresh_error_message', $reason . ': ' . $message);
  if (\Drupal::hasService('calendly_availability.alerts')) {
    \Drupal::service('calendly_availability.alerts')->notifyRefreshFailure($reason, $message);
  }
}

/**
 * Implements hook_mail().
 */
function calendly_availability_mail($key, &$message, $params) {
  if ($key === 'alert') {
    $message['subject'] = $params['subject'] ?? 'Calendly Availability alert';
    $message['body'][] = $params['body'] ?? '';
    $message['headers']['Content-Type'] = 'text/plain; charset=UTF-8';
  }
}

/**
 * Implements hook_help().
 */
function calendly_availability_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    // Main module help for the calendly_availability module.
    case 'help.page.calendly_availability':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Provides a block to display aggregated Calendly availability.') . '</p>';
      return $output;

    default:
  }
}

/**
 * Implements hook_theme().
 */
function calendly_availability_theme($existing, $type, $theme, $path) {
  return [
    'calendly_availability_block' => [
      'variables' => [
        'available_slots' => [],
        'button_action_text_config' => 'Schedule', // UPDATED
        'fallback_url' => NULL,                  // NEW or ensure it's there
        'fallback_link_text_config' => NULL,     // NEW or ensure it's there
      ],
    ],
    'calendly_availability_week_schedule' => [
      'variables' => [
        'schedule_data' => [], 
        'button_action_text_config' => 'Schedule', // UPDATED
        'fallback_url' => NULL,                  // NEW or ensure it's there
        'fallback_link_text_config' => NULL,     // NEW or ensure it's there
      ],
    ],
    'calendly_availability_fallback' => [
      'variables' => [
        'fallback_url' => '',
        'message_for_fallback' => '', // Name used in build()
        'fallback_link_text_config' => '', // Name used in build()
      ],
    ],
    'calendly_availability_stats' => [
      'variables' => [
        'stats' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_makerspace_snapshot_collect_kpi().
 */
function calendly_availability_makerspace_snapshot_collect_kpi(array $context): array {
  if (!\Drupal::hasService('calendly_availability.stats_collector')) {
    return [];
  }

  $periodTimestamp = !empty($context['snapshot_date']) ? strtotime($context['snapshot_date']) : \Drupal::time()->getRequestTime();
  $periodYear = (int) date('Y', $periodTimestamp);
  $periodMonth = (int) date('n', $periodTimestamp);

  $options = [
    'suppress_availability' => TRUE,
  ];
  if (!empty($context['period_start'])) {
    $options['start'] = new DrupalDateTime($context['period_start']);
  }
  if (!empty($context['period_end'])) {
    $options['end'] = new DrupalDateTime($context['period_end']);
  }

  try {
    $stats = \Drupal::service('calendly_availability.stats_collector')->collect($options);
  }
  catch (\Exception $e) {
    \Drupal::logger('calendly_availability')->error('Failed to collect Calendly KPIs: @msg', ['@msg' => $e->getMessage()]);
    return [];
  }

  if (($stats['status'] ?? '') !== 'ok') {
    return [];
  }

  $snapshot = $stats['snapshot'] ?? [];

  return [
    'calendly_tours_completed' => [
      'value' => $snapshot['tours'] ?? 0,
      'period_year' => $periodYear,
      'period_month' => $periodMonth,
    ],
    'calendly_orientations_completed' => [
      'value' => $snapshot['orientations'] ?? 0,
      'period_year' => $periodYear,
      'period_month' => $periodMonth,
    ],
    'calendly_other_meetings_completed' => [
      'value' => $snapshot['other_meetings'] ?? 0,
      'period_year' => $periodYear,
      'period_month' => $periodMonth,
    ],
    'calendly_total_events' => [
      'value' => $snapshot['total_events'] ?? 0,
      'period_year' => $periodYear,
      'period_month' => $periodMonth,
    ],
  ];
}
